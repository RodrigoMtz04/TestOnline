# Archivo de Ejemplo para Variables de Entorno
# Copia este archivo a .env y modifica según sea necesario

# Servidor
PORT=3000
NODE_ENV=development

# Socket.io
SOCKET_IO_CORS=*
SOCKET_IO_TRANSPORTS=websocket,polling

# Base de Datos (Opcional)
# DATABASE_URL=mongodb+srv://usuario:password@cluster.mongodb.net/dbname
# REDIS_URL=redis://:password@host:port

# Vercel
# VERCEL_ENV=production
# VERCEL_URL=https://tu-proyecto.vercel.app

# Analíticos (Opcional)
# GA_ID=UA-XXXXXXXXX-X

